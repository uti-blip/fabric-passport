# Database (SQLite for dev, PostgreSQL URL for prod)
DATABASE_URL=sqlite:///fabric_passport.db

# Security
SECRET_KEY=change-me-in-production-at-least-32-chars-random

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,https://fabric-passport.vercel.app

# App
APP_ENV=production
DEBUG=false
